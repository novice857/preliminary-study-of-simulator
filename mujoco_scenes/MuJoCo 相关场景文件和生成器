A simple model：
xml = """
<mujoco>
  <worldbody>
    <geom name="red_box" type="box" size=".2 .2 .2" rgba="1 0 0 1"/>
    <geom name="green_sphere" pos=".2 .2 .2" size=".1" rgba="0 1 0 1"/>
  </worldbody>
</mujoco>
"""
model = mujoco.MjModel.from_xml_string(xml)

#静态model不随时间变化，<mujoco>根元素，<worldbody>世界主体，<geom》几何元素，默认位置[0,0,0]。
#mjmodel包含几何信息，连接关系，物理关系，视觉属性，rgba对应颜色和透明度

#颜色透明度
model.geom_rgba
#数量
model.ngeom
#命名
try:
  model.geom()
except KeyError as e:
  print(e)
#通过name，访问所有属性*  
model.geom('green_sphere')
#通过name，访问单一属性
model.geom('green_sphere').rgba
#通过ID访问属性
id = mujoco.mj_name2id(model, mujoco.mjtObj.mjOBJ_GEOM, 'green_sphere')
model.geom_rgba[id, :]
#id，name互查，id=0永远是world
print('id of "green_sphere": ', model.geom('green_sphere').id)
print('name of geom 1: ', model.geom(1).name)
print('name of body 0: ', model.body(0).name)
#列出所有name，id
[model.geom(i).name for i in range(model.ngeom)]
[model.geom(i).id for i in range(model.ngeom)]

#mjData是动态仿真模型:data.time. 广义/关节坐标：data.qpos data.qvel 笛卡尔：data.xpos data.xquat

#创建mjData实例
data = mujoco.MjData(model)
#打印位置，不会更新位置
print(data.geom_xpos)

#调用mujoco.mj_kinematics计算运动学，更新位置
mujoco.mj_kinematics(model, data)
#打印正确位置
print('raw access:\n', data.geom_xpos)

# MjData also supports named access:
print('\nnamed access:\n', data.geom('green_sphere').xpos)


